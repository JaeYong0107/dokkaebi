# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Prisma (Docker Compose 기본값: docker-compose.yml 참고)
DATABASE_URL="postgresql://dokkaebi:dokkaebi@localhost:5432/dokkaebi?schema=public"

# 결제 (MVP mock)
PAYMENT_PROVIDER="mock"
PAYMENT_API_KEY="mock-key"

# 정책 기본값 (DB Policy 가 비어있을 때 fallback)
DEFAULT_SHIPPING_FEE="3000"
FREE_SHIPPING_THRESHOLD="50000"
MIN_ORDER_NORMAL="10000"
MIN_ORDER_BUSINESS="50000"

# 시드 옵션 (로컬 개발에서만 "1" 로 설정)
# · 미설정: 카테고리/상품만 주입
# · "1": 추가로 admin/user/biz 테스트 계정 + 샘플 주문 주입
SEED_DEV_DATA="1"
